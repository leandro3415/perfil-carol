{
  "name": "PushinPay — Gerar PIX (checkout)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "pix-push",
        "responseMode": "responseNode",
        "options": {
          "allowedOrigins": "*"
        }
      },
      "id": "a1b2c3d0-1111-4aaa-8bbb-000000000001",
      "name": "Webhook Chamar Pix",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 0],
      "webhookId": "pix-push-checkout-pushinpay"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "v1",
              "name": "id_lead",
              "value": "={{ $json.body?.id != null ? String($json.body.id) : '' }}",
              "type": "string"
            },
            {
              "id": "v2",
              "name": "value",
              "value": "={{ $json.body?.value }}",
